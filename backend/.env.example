# === Application ===
APP_NAME=UrbanSynapse AI
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === Base de données ===
# Par défaut : SQLite (aucune installation requise, fichier local urbansynapse.db)
DATABASE_URL=sqlite:///./urbansynapse.db

# Pour PostgreSQL + PostGIS (production), commenter la ligne ci-dessus et décommenter :
# DATABASE_URL=postgresql+psycopg2://urbansynapse:urbansynapse@localhost:5432/urbansynapse

# === Redis / Celery (optionnel en dev) ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === CORS ===
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# === GIS / Projections ===
DEFAULT_SRID=4326
PROJECTED_SRID=30729   # Nord Sahara 1959 / UTM zone 29N (Algérie)

# === ML ===
ML_MODEL_DIR=app/ml/models

# === IA générative (planification prospective) ===
# Clé API Mistral (optionnelle). Sans elle, un plan structuré local est généré.
# Obtenir une clé : https://console.mistral.ai/
MISTRAL_API_KEY=
